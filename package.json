{
  "name": "covertone",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "android:build": "pnpm build && pnpm exec cap sync && cd android && ./gradlew assembleDebug -Pandroid.aapt2FromMavenOverride=$ANDROID_HOME/build-tools/36.0.0/aapt2",
    "android:open": "pnpm build && pnpm exec cap sync && pnpm exec cap open android",
    "lint": "prettier --check src/ && eslint src/ && pnpm exec svelte-check",
    "format": "prettier --write src/",
    "typecheck": "pnpm exec svelte-check",
    "lint:eslint": "eslint src/",
    "lint:format": "prettier --check src/",
    "lint:svelte": "pnpm exec svelte-check"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "md5": "^2.3.0"
  }
}
